AIRFLOW_ADMIN_USERNAME=change-me
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=change-me

BATCH_JOB_NAME=cdc_spark_reconcile
SPARK_MASTER=local[*]

SUPERSET_SECRET_KEY=change-me
SUPERSET_TALISMAN_ENABLED=false
SUPERSET_ADMIN_USERNAME=change-me
SUPERSET_ADMIN_FIRSTNAME=Admin
SUPERSET_ADMIN_LASTNAME=User
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=change-me
