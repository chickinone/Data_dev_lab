SOURCE_DB_HOST=postgres-source
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=sourcedb
SOURCE_DB_USER=change-me
SOURCE_DB_PASSWORD=change-me

TARGET_DB_HOST=postgres-target
TARGET_DB_PORT=5432
TARGET_DB_NAME=targetdb
TARGET_DB_USER=change-me
TARGET_DB_PASSWORD=change-me

KAFKA_BOOTSTRAP=kafka:29092
TOPIC_PREFIX=dbserver1
DLQ_TOPIC=cdc.failed_events
MAX_RETRIES=3

DEBEZIUM_CONNECTOR_NAME=ecommerce-source-connector
DEBEZIUM_SLOT_NAME=debezium_slot
DEBEZIUM_PUBLICATION_NAME=dbz_publication

POISON_EVENTS=4

AIRFLOW_LOAD_EXAMPLES=false
AIRFLOW_DAGS_ARE_PAUSED_AT_CREATION=false
